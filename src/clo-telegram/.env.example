# 텔레그램 봇 토큰 (BotFather에서 발급)
TELEGRAM_BOT_TOKEN=

# AI 프로바이더 선택: anthropic | openai | gemini
PROVIDER=openai

# API 키 (선택한 프로바이더의 키만 있으면 됨)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# 허용 chat_id 목록 (쉼표 구분, @userinfobot으로 확인)
OWNER_CHAT_IDS=

# Brain 디렉토리 절대 경로
BRAIN_ROOT=C:\Projects\Brain

# 모델 (비워두면 프로바이더별 기본값: claude-sonnet-4, gpt-4o, gemini-2.0-flash)
MODEL=

# 세션 저장 경로
SESSION_DIR=./data/sessions
